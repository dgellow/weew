{
  "name": "@dgellow/weew",
  "version": "0.5.0",
  "license": "MIT",
  "exports": "./mod.ts",
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "tasks": {
    "demo": "deno run -A examples/demo.ts",
    "music": "deno run -A examples/music-app/deno.ts",
    "simple": "deno run -A examples/simple.ts",
    "check": "deno check",
    "test": "deno test -A",
    "bench": "deno bench --allow-all src/bench.ts",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
